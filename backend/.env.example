# Database (lokaal OF Supabase)
# Lokaal:
# DATABASE_URL="postgresql://user:password@localhost:5432/coldmonitor?schema=public"
# Supabase (direct): Project Settings → Database → Connection string
# DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
# Supabase (pooled voor serverless): port 6543
# DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# JWT Authentication
# JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL(s) voor CORS - comma-separated voor meerdere origins
# LOKAAL:
FRONTEND_URL="http://localhost:5173"

# RAILWAY (na deployment): lokaal + cloud, bv.
# FRONTEND_URL="https://www.intellifrost.be,http://localhost:5173"

# Email Service (for notifications - optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password

# Push Notifications (for mobile app - optional)
# FCM_SERVER_KEY=your-fcm-server-key

# Rate Limiting (optional - defaults shown)
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
# RATE_LIMIT_MAX=1500  # Max requests per 15 min (default; verhoog bij veel polling/tabs)
# AUTH_RATE_LIMIT_MAX=50  # Max failed auth attempts per window (development: 50, production: 20)

# API URL (voor e-mailverificatielinks)
# API_URL=https://api.jouwdomein.com

# E-mail (verificatie + alarm) – Resend HTTP API (aanbevolen, geen SMTP nodig)
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_EMAIL=alerts@intellifrost.be
# EMAIL_FROM=onboarding@resend.dev

# Escalatie: Twilio (SMS + AI-telefoon)
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+32123456789

# Escalatie: ElevenLabs (TTS voor AI-telefoonbot) - zie elevenlabs.io/docs/eleven-api/quickstart
# API key: elevenlabs.io/app/settings/api-keys
# Voice ID: elevenlabs.io/voice-library (of je custom voice clone)
# ELEVENLABS_API_KEY=xxxxxxxx
# ELEVENLABS_VOICE_ID=xxxxxxxx

# Escalatie-cron: POST /api/escalate (elke minuut via n8n/cron)
# CRON_SECRET=geheime-string  # Zet in productie om ongeautoriseerde calls te blokkeren

# API URL (voor e-mailverificatie, Twilio webhooks, TTS-audio)
# API_URL=https://api.intellifrost.be  # Of Railway URL

# OF: SMTP (fallback) – bij Resend: SMTP_PASS = API key, wordt automatisch voor HTTP API gebruikt
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxx
# EMAIL_FROM=onboarding@resend.dev
